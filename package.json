    "test:heighted-authenticated-evidence": "quint test spec/CrosslinkHeightedAuthenticatedEvidence.qnt --main=CrosslinkHeightedAuthenticatedEvidenceModel --max-samples=100 --backend=rust",
    "verify": "npm run verify:baseline-safety && npm run verify:resampling-safety && npm run verify:finality-safety && npm run verify:composed-safety && npm run verify:multi-height-safety && npm run verify:heighted-round-safety && npm run verify:heighted-finality-safety && npm run verify:evidence-gossip-safety && npm run verify:heighted-evidence-gossip-safety && npm run verify:message-auth-safety && npm run verify:heighted-message-auth-safety && npm run verify:validator-set-change-safety && npm run verify:heighted-validator-evidence-safety && npm run verify:heighted-authenticated-evidence-safety && npm run verify:scheduler-liveness-safety && npm run verify:head-sigma-safety && npm run verify:heighted-head-sigma-safety && npm run verify:bft-block-shape-safety",
    "verify:baseline-safety": "quint verify spec/CrosslinkResampling.qnt --main=BaselineCrosslink --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:resampling-safety": "quint verify spec/CrosslinkResampling.qnt --main=NilPrecommitResamplingCrosslink --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:finality-safety": "quint verify spec/CrosslinkForkFinality.qnt --main=CrosslinkForkFinalityModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:composed-safety": "quint verify spec/CrosslinkComposed.qnt --main=CrosslinkComposedResamplingModel --init=ComposedInit --step=ComposedNext --invariants=ComposedSafety --max-steps=3",
    "verify:multi-height-safety": "quint verify spec/CrosslinkMultiHeight.qnt --main=CrosslinkMultiHeightModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:heighted-round-safety": "quint verify spec/CrosslinkHeightedRound.qnt --main=CrosslinkHeightedRoundModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:heighted-finality-safety": "quint verify spec/CrosslinkHeightedFinality.qnt --main=CrosslinkHeightedFinalityModel --init=ComposedInit --step=ComposedNext --invariants=ComposedSafety --max-steps=3",
    "verify:evidence-gossip-safety": "quint verify spec/CrosslinkEvidenceGossip.qnt --main=CrosslinkEvidenceGossipModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:heighted-evidence-gossip-safety": "quint verify spec/CrosslinkHeightedEvidenceGossip.qnt --main=CrosslinkHeightedEvidenceGossipModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:message-auth-safety": "quint verify spec/CrosslinkMessageAuth.qnt --main=CrosslinkMessageAuthModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:heighted-message-auth-safety": "quint verify spec/CrosslinkHeightedMessageAuth.qnt --main=CrosslinkHeightedMessageAuthModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:validator-set-change-safety": "quint verify spec/CrosslinkValidatorSetChange.qnt --main=CrosslinkValidatorSetChangeModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:heighted-validator-evidence-safety": "quint verify spec/CrosslinkHeightedValidatorEvidence.qnt --main=CrosslinkHeightedValidatorEvidenceModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:heighted-authenticated-evidence-safety": "quint verify spec/CrosslinkHeightedAuthenticatedEvidence.qnt --main=CrosslinkHeightedAuthenticatedEvidenceModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:scheduler-liveness-safety": "quint verify spec/CrosslinkSchedulerLiveness.qnt --main=CrosslinkSchedulerLivenessModel --init=SchedulerInit --step=SchedulerStep --invariants=SchedulerSafety --max-steps=3",
    "verify:head-sigma-safety": "quint verify spec/CrosslinkHeadSigmaSampling.qnt --main=CrosslinkHeadSigmaSamplingModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:heighted-head-sigma-safety": "quint verify spec/CrosslinkHeightedHeadSigmaRound.qnt --main=CrosslinkHeightedHeadSigmaRoundModel --init=Init --step=Next --invariants=HeadSigmaSafety --max-steps=3",
    "verify:bft-block-shape-safety": "quint verify spec/CrosslinkBftBlockShape.qnt --main=CrosslinkBftBlockShapeModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:extended": "npm run verify:extended:head-sigma && npm run verify:extended:heighted-head-sigma && npm run verify:extended:bft-block-shape && npm run verify:extended:heighted-validator-evidence && npm run verify:extended:heighted-authenticated-evidence",
    "verify:extended:head-sigma": "quint verify spec/CrosslinkHeadSigmaSampling.qnt --main=CrosslinkHeadSigmaSamplingModel --init=Init --step=Next --invariants=Safety --max-steps=5",
    "verify:extended:heighted-head-sigma": "quint verify spec/CrosslinkHeightedHeadSigmaRound.qnt --main=CrosslinkHeightedHeadSigmaRoundModel --init=Init --step=Next --invariants=HeadSigmaSafety --max-steps=5",
    "verify:extended:bft-block-shape": "quint verify spec/CrosslinkBftBlockShape.qnt --main=CrosslinkBftBlockShapeModel --init=Init --step=Next --invariants=Safety --max-steps=5",
    "verify:extended:heighted-validator-evidence": "quint verify spec/CrosslinkHeightedValidatorEvidence.qnt --main=CrosslinkHeightedValidatorEvidenceModel --init=Init --step=Next --invariants=Safety --max-steps=5",
    "verify:extended:heighted-authenticated-evidence": "quint verify spec/CrosslinkHeightedAuthenticatedEvidence.qnt --main=CrosslinkHeightedAuthenticatedEvidenceModel --init=Init --step=Next --invariants=Safety --max-steps=5"
  },
  "devDependencies": {
    "@informalsystems/quint": "0.31.0"
