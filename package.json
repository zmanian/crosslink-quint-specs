{
  "name": "crosslink-quint-specs",
  "version": "0.1.0",
  "private": true,
  "description": "Quint specifications for baseline Crosslink and nil-precommit resampling variants",
  "scripts": {
    "typecheck": "quint typecheck spec/CrosslinkResampling.qnt && quint typecheck spec/CrosslinkForkFinality.qnt && quint typecheck spec/CrosslinkComposed.qnt",
    "test": "npm run typecheck && npm run test:baseline && npm run test:resampling && npm run test:liveness && npm run test:finality && npm run test:composed",
    "test:baseline": "quint test spec/CrosslinkResampling.qnt --main=BaselineCrosslink --max-samples=100 --backend=rust",
    "test:resampling": "quint test spec/CrosslinkResampling.qnt --main=NilPrecommitResamplingCrosslink --max-samples=100 --backend=rust",
    "test:liveness": "quint test spec/CrosslinkResampling.qnt --main=NilPrecommitResamplingStableWindowLiveness --max-samples=100 --backend=rust",
    "test:finality": "quint test spec/CrosslinkForkFinality.qnt --main=CrosslinkForkFinalityModel --max-samples=100 --backend=rust",
    "test:composed": "quint test spec/CrosslinkComposed.qnt --main=CrosslinkComposedResamplingModel --max-samples=100 --backend=rust",
    "verify": "npm run verify:baseline-safety && npm run verify:resampling-safety && npm run verify:finality-safety && npm run verify:composed-safety",
    "verify:baseline-safety": "quint verify spec/CrosslinkResampling.qnt --main=BaselineCrosslink --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:resampling-safety": "quint verify spec/CrosslinkResampling.qnt --main=NilPrecommitResamplingCrosslink --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:finality-safety": "quint verify spec/CrosslinkForkFinality.qnt --main=CrosslinkForkFinalityModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:composed-safety": "quint verify spec/CrosslinkComposed.qnt --main=CrosslinkComposedResamplingModel --init=ComposedInit --step=ComposedNext --invariants=ComposedSafety --max-steps=3"
  },
  "devDependencies": {
    "@informalsystems/quint": "0.31.0"
  }
}
