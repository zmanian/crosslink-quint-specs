{
  "name": "crosslink-quint-specs",
  "version": "0.1.0",
  "private": true,
  "description": "Quint specifications for baseline Crosslink and nil-precommit resampling variants",
  "scripts": {
    "typecheck": "quint typecheck spec/CrosslinkResampling.qnt && quint typecheck spec/CrosslinkForkFinality.qnt && quint typecheck spec/CrosslinkComposed.qnt && quint typecheck spec/CrosslinkMultiHeight.qnt && quint typecheck spec/CrosslinkHeightedRound.qnt && quint typecheck spec/CrosslinkHeightedFinality.qnt && quint typecheck spec/CrosslinkEvidenceGossip.qnt && quint typecheck spec/CrosslinkHeightedEvidenceGossip.qnt && quint typecheck spec/CrosslinkMessageAuth.qnt && quint typecheck spec/CrosslinkHeightedMessageAuth.qnt",
    "test": "npm run typecheck && npm run test:baseline && npm run test:resampling && npm run test:evidence && npm run test:weighted && npm run test:message-evidence && npm run test:local-delivery && npm run test:timeout && npm run test:liveness && npm run test:proposal-validity && npm run test:valid-round && npm run test:finality && npm run test:composed && npm run test:composed-liveness && npm run test:multi-height && npm run test:heighted-round && npm run test:heighted-finality && npm run test:evidence-gossip && npm run test:heighted-evidence-gossip && npm run test:message-auth && npm run test:heighted-message-auth",
    "test:baseline": "quint test spec/CrosslinkResampling.qnt --main=BaselineCrosslink --max-samples=100 --backend=rust",
    "test:resampling": "quint test spec/CrosslinkResampling.qnt --main=NilPrecommitResamplingCrosslink --max-samples=100 --backend=rust",
    "test:evidence": "quint test spec/CrosslinkResampling.qnt --main=CrosslinkEvidenceBookkeepingModel --max-samples=100 --backend=rust",
    "test:weighted": "quint test spec/CrosslinkResampling.qnt --main=CrosslinkWeightedQuorumModel --max-samples=100 --backend=rust",
    "test:message-evidence": "quint test spec/CrosslinkResampling.qnt --main=CrosslinkMessageEvidenceModel --max-samples=100 --backend=rust",
    "test:local-delivery": "quint test spec/CrosslinkResampling.qnt --main=CrosslinkLocalDeliveryModel --max-samples=100 --backend=rust",
    "test:timeout": "quint test spec/CrosslinkResampling.qnt --main=CrosslinkTimeoutModel --max-samples=100 --backend=rust",
    "test:liveness": "quint test spec/CrosslinkResampling.qnt --main=NilPrecommitResamplingStableWindowLiveness --max-samples=100 --backend=rust",
    "test:proposal-validity": "quint test spec/CrosslinkResampling.qnt --main=CrosslinkProposalValidityModel --max-samples=100 --backend=rust",
    "test:valid-round": "quint test spec/CrosslinkResampling.qnt --main=CrosslinkValidRoundModel --max-samples=100 --backend=rust",
    "test:finality": "quint test spec/CrosslinkForkFinality.qnt --main=CrosslinkForkFinalityModel --max-samples=100 --backend=rust",
    "test:composed": "quint test spec/CrosslinkComposed.qnt --main=CrosslinkComposedResamplingModel --max-samples=100 --backend=rust",
    "test:composed-liveness": "quint test spec/CrosslinkComposed.qnt --main=CrosslinkComposedLivenessModel --max-samples=100 --backend=rust",
    "test:multi-height": "quint test spec/CrosslinkMultiHeight.qnt --main=CrosslinkMultiHeightModel --max-samples=100 --backend=rust",
    "test:heighted-round": "quint test spec/CrosslinkHeightedRound.qnt --main=CrosslinkHeightedRoundModel --max-samples=100 --backend=rust",
    "test:heighted-finality": "quint test spec/CrosslinkHeightedFinality.qnt --main=CrosslinkHeightedFinalityModel --max-samples=100 --backend=rust",
    "test:evidence-gossip": "quint test spec/CrosslinkEvidenceGossip.qnt --main=CrosslinkEvidenceGossipModel --max-samples=100 --backend=rust",
    "test:heighted-evidence-gossip": "quint test spec/CrosslinkHeightedEvidenceGossip.qnt --main=CrosslinkHeightedEvidenceGossipModel --max-samples=100 --backend=rust",
    "test:message-auth": "quint test spec/CrosslinkMessageAuth.qnt --main=CrosslinkMessageAuthModel --max-samples=100 --backend=rust",
    "test:heighted-message-auth": "quint test spec/CrosslinkHeightedMessageAuth.qnt --main=CrosslinkHeightedMessageAuthModel --max-samples=100 --backend=rust",
    "verify": "npm run verify:baseline-safety && npm run verify:resampling-safety && npm run verify:finality-safety && npm run verify:composed-safety && npm run verify:multi-height-safety && npm run verify:heighted-round-safety && npm run verify:heighted-finality-safety && npm run verify:evidence-gossip-safety && npm run verify:heighted-evidence-gossip-safety && npm run verify:message-auth-safety && npm run verify:heighted-message-auth-safety",
    "verify:baseline-safety": "quint verify spec/CrosslinkResampling.qnt --main=BaselineCrosslink --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:resampling-safety": "quint verify spec/CrosslinkResampling.qnt --main=NilPrecommitResamplingCrosslink --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:finality-safety": "quint verify spec/CrosslinkForkFinality.qnt --main=CrosslinkForkFinalityModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:composed-safety": "quint verify spec/CrosslinkComposed.qnt --main=CrosslinkComposedResamplingModel --init=ComposedInit --step=ComposedNext --invariants=ComposedSafety --max-steps=3",
    "verify:multi-height-safety": "quint verify spec/CrosslinkMultiHeight.qnt --main=CrosslinkMultiHeightModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:heighted-round-safety": "quint verify spec/CrosslinkHeightedRound.qnt --main=CrosslinkHeightedRoundModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:heighted-finality-safety": "quint verify spec/CrosslinkHeightedFinality.qnt --main=CrosslinkHeightedFinalityModel --init=ComposedInit --step=ComposedNext --invariants=ComposedSafety --max-steps=3",
    "verify:evidence-gossip-safety": "quint verify spec/CrosslinkEvidenceGossip.qnt --main=CrosslinkEvidenceGossipModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:heighted-evidence-gossip-safety": "quint verify spec/CrosslinkHeightedEvidenceGossip.qnt --main=CrosslinkHeightedEvidenceGossipModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:message-auth-safety": "quint verify spec/CrosslinkMessageAuth.qnt --main=CrosslinkMessageAuthModel --init=Init --step=Next --invariants=Safety --max-steps=3",
    "verify:heighted-message-auth-safety": "quint verify spec/CrosslinkHeightedMessageAuth.qnt --main=CrosslinkHeightedMessageAuthModel --init=Init --step=Next --invariants=Safety --max-steps=3"
  },
  "devDependencies": {
    "@informalsystems/quint": "0.31.0"
  }
}
